# Continuum environment.
# On first `npm run dev`, a .env is generated automatically — you almost
# never need to edit this. Listed here for reference + self-hosting.

# Postgres connection string. Required — you set this.
#   Example: postgresql://username:password@localhost:5432/continuum
# If you don't have a Postgres anywhere, `docker compose up -d` from the repo
# root will spin one up; then use:
#   postgresql://continuum:continuum@localhost:5432/continuum
DATABASE_URL=""

# 32-byte hex key used to encrypt API keys at rest.
# Auto-generated on first run if missing.
ENCRYPTION_KEY=""

# Optional fallback API keys. The /settings page can override these per-instance.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Shared token Claude Code hooks must send in X-Continuum-Token header.
# Auto-generated on first run if missing.
CONTINUUM_TOKEN=""

# Set to "1" to use a canned mock AI provider (no API keys needed).
# Useful for screenshots, demos, and trying out the UI before adding keys.
DEMO_MODE=""
