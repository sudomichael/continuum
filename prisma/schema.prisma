// Continuum schema. Postgres only.
//
// Local dev: `docker compose up -d` (ships in repo) → postgres on :5432.
// Hosted:    point DATABASE_URL at Neon, Supabase, RDS, etc.
//
// Tenancy model
// -------------
// Every user-owned model carries a `workspaceId`. In self-host mode we
// auto-create a single workspace named "personal" on first boot and pin
// everything to it. In cloud mode (CONTINUUM_MULTI_TENANT=1) every Clerk
// user gets a workspace on signup; the Prisma client is wrapped with an
// extension that injects `where: { workspaceId }` into every query so
// route handlers can't accidentally read across tenants.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Tenancy ---------------------------------------------------------------

// A User is the Clerk-authenticated identity, mirrored locally so we have
// foreign keys to point at. The `externalId` is the Clerk user id (`user_…`).
// In self-host mode we still create one User row so cloud-mode and
// self-host-mode code paths look identical; the row's externalId is just
// `"self-hosted"` then.
model User {
  id         String   @id @default(cuid())
  externalId String   @unique
  email      String?
  name       String?
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships WorkspaceMember[]
}

// A Workspace owns all the project data. Free-tier limits + billing live
// here. In self-host mode there's exactly one Workspace ("personal")
// auto-created by bootstrap.ts.
model Workspace {
  id        String   @id @default(cuid())
  slug      String   @unique  // shown in URLs / CLI metadata
  name      String
  tier      String   @default("free") // free | pro | team | self_hosted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      WorkspaceMember[]
  projects     Project[]
  cliTokens    CliToken[]
  cliPairings  CliPairing[]
  settings     Settings?
  usageEvents  UsageEvent[]
}

// Many-to-many between User and Workspace so a single user can belong to
// multiple workspaces (own + collaborator). For now only OWNER role; ROLE
// is reserved for later team features.
model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String   @default("owner") // owner | member (reserved)
  createdAt   DateTime @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

// ---- Project data ----------------------------------------------------------

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  slug        String
  name        String
  identifier  String?
  icon        String?
  description String?
  cwd         String?
  state       String   @default("active") // active | near_launch | paused | exploring | archived
  momentum    Int      @default(50)
  health      Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brain     Brain?
  updates   Update[]
  threads   WorkThread[]
  decisions Decision[]

  // Slugs + cwds are unique PER WORKSPACE so two users can both have a
  // project called "parcelwise" without collision.
  @@unique([workspaceId, slug])
  @@unique([workspaceId, cwd])
  @@index([workspaceId, updatedAt])
}

// The synthesized snapshot of a project. Five user-facing sections (plus
// currentFocus for the dashboard preview), shaped around "rapid contextual
// rehydration" — re-read this on a tired Sunday and instantly recognize
// where things stand. NOT a task list, NOT prescriptive.
model Brain {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // One observational sentence. Shown on the dashboard preview row.
  currentFocus         String?
  // What this project IS right now (purpose + current operational reality).
  currentState         String?
  // What's moved recently (bullets, descriptive past/present).
  whatChangedRecently  String?
  // Where work is currently aimed (descriptive, not prescriptive).
  currentDirection     String?
  // Stack + key load-bearing technical decisions.
  architectureSnapshot String?
  // Active conversations, unresolved questions, in-flight work.
  openThreads          String?

  lastSynthesizedAt DateTime?
  synthesisModel    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Update {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source          String   // claude_code | codex | manual | git | prd
  category        String   // session | decision | blocker | architecture | idea | progress | next_action
  title           String?
  body            String
  raw             String?
  sourceSessionId String?
  createdAt       DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([source, sourceSessionId])
}

model WorkThread {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  state       String   @default("active")
  context     String?
  blockers    String?
  nextActions String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, state])
}

model Decision {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  rationale       String?
  source          String?
  sourceSessionId String?
  createdAt       DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([source, sourceSessionId])
}

// ---- CLI auth (workspace-scoped) -------------------------------------------

model CliToken {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  name        String
  platform    String?
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime?

  @@index([workspaceId])
}

model CliPairing {
  id          String    @id @default(cuid())
  // Workspace is filled in at authorize-time, not start-time. Until then
  // we don't know who's pairing.
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  code        String    @unique
  authorized  Boolean   @default(false)
  token       String?
  tokenId     String?
  platform    String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

// ---- Settings (one row per workspace) --------------------------------------

model Settings {
  workspaceId String   @id  // one Settings per workspace
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Single-user web auth lives here ONLY in self-host mode. In cloud mode
  // we use Clerk; this column is null.
  passwordHash String?

  smartProvider  String  @default("anthropic")
  smartBaseUrl   String  @default("https://api.anthropic.com")
  smartModel     String  @default("claude-sonnet-4-6")
  smartKeyCipher String?

  cheapProvider  String  @default("anthropic")
  cheapBaseUrl   String  @default("https://api.anthropic.com")
  cheapModel     String  @default("claude-haiku-4-5")
  cheapKeyCipher String?

  updatedAt DateTime @updatedAt
}

// ---- Usage metering --------------------------------------------------------

// One row per billable event (session ingested, brain synthesized, etc).
// Used to enforce free-tier limits and, later, meter paid usage. Keep the
// shape small and add columns lazily.
model UsageEvent {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  kind        String   // session_ingested | brain_synthesized | capture_classified
  // Optional token-cost tracking for honest pricing later. Null when unknown.
  inputTokens  Int?
  outputTokens Int?
  costUsd      Float?
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
}
